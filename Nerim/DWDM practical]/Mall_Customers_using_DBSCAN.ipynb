In [10]: 	#From the above plot, we note the maximum curvature of the curve is about eight, 
	#and thus we picked our Eps as 8. We now have our two parameters as: MinPoints = 4 and Eps = 8
	#Implementing the DBSCAN model
	from sklearn.cluster import DBSCAN
	# cluster the data into five clusters
	dbscan = DBSCAN(eps = 8, min_samples = 4).fit(x) # fitting the model
	labels = dbscan.labels_ # getting the labels
	# Plot the clusters
	plt.scatter(x[:, 0], x[:,1], c = labels, cmap= "plasma") # plotting the clusters
	plt.xlabel("Income") # X-axis label
	plt.ylabel("Spending Score") # Y-axis label
	plt.show() # showing the plot

